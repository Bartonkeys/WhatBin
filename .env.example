# PostgreSQL configuration for local development
# Copy this file to .env and update values as needed:
#   cp .env.example .env

POSTGRES_DB=whatbin
POSTGRES_USER=whatbin
POSTGRES_PASSWORD=whatbin_dev

# Connection string used by backend and DataSeeder
# Set this as an environment variable or in appsettings.Development.json
CONNECTION_STRING=Host=localhost;Port=5432;Database=whatbin;Username=whatbin;Password=whatbin_dev
